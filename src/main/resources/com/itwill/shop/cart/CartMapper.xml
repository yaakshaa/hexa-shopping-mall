<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.itwill.shop.cart.CartMapper">

    <!-- resultMap 정의 -->
    <resultMap id="cartResultMap" type="com.itwill.shop.cart.Cart" autoMapping="true">
        <id column="cart_no" property="cartNo"/>
        <result column="cart_qty" property="cartQty"/>  
        <result column="member_id" property="memberId"/>
        
        <!-- Product 객체 매핑 -->
        <association property="product" javaType="com.itwill.shop.product.Product" autoMapping="true">
            <id column="product_no" property="productNo"/>
            <result column="product_name" property="productName"/>
            <result column="product_price" property="productPrice"/>
            <result column="product_stock" property="productStock"/>
            <result column="product_desc" property="productDesc"/>
            <result column="product_img" property="productImg"/>
            <result column="category_no" property="categoryNo"/>
        </association>
    </resultMap>

    <select id="findCartByMemberId" resultMap="cartResultMap" parameterType="string">
        SELECT cart.cart_no, cart.member_id, product.product_no, product.product_img, product.product_name, cart.cart_qty, product.product_price
        FROM cart
        JOIN product
        ON cart.product_no = product.product_no
        WHERE member_id = #{memberId}
    </select>

    <select id="findCartByMemberIdForLogic" resultMap="cartResultMap" parameterType="string">
        SELECT cart.*, product.* 
        FROM cart 
        JOIN product ON cart.product_no = product.product_no 
        WHERE member_id = #{memberId}
    </select>

</mapper>
